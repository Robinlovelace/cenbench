{
  "name": "Cenbench",
  "build": {
    "dockerfile": "../Dockerfile",
    "context": ".."
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "quarto.quarto",
        "GitHub.vscode-pull-request-github"
      ]
    }
  },
  "postCreateCommand": "dvc pull",
  "containerEnv": {
    "PYTHONPATH": "/workspace",
    "SDNADLL": "/opt/sdna/lib/sdna_vs2008.so"
  }
}
